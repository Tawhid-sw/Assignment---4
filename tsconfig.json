{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": "./",
    "paths": {
      "@/src/*": ["src/*"],
      "@/generated/*": ["generated/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "generated/**/*", "api/**/*"],
  "exclude": ["node_modules", "dist"]
}
